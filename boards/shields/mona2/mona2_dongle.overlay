#include "mona2.dtsi"

// 左右からのキー入力を1文字もこぼさず受け取るため、
// 元の受け皿（kscan0）をそのままダミー化して再利用します。
&kscan0 {
    compatible = "zmk,kscan-mock";
    columns = <11>;
    rows = <4>;
    events = <0>;
    
    // ディスプレイ（SPI/I2C）とのピン競合・クラッシュを防ぐため、物理ピン設定だけを削除します
    /delete-property/ row-gpios;
    /delete-property/ col-gpios;
    /delete-property/ diode-direction;
};

// ※ &sensors の無効化は絶対に書きません！（エンコーダーを殺さないため）
// ※ ディスプレイ(xiaord)用の特別な上書きも不要です。モジュールは自動で動きます。
