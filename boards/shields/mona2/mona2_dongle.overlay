#include "mona2.dtsi"

/ {
    chosen {
        zmk,kscan = &xiaord_mock_kscan;
    };

    // kscan0 を完全に削除して再定義
    /delete-node/ kscan;
    
    kscan0: kscan {
        compatible = "zmk,kscan-mock";
        columns = <11>;
        rows = <4>;
        events = <0>;
    };
};

&left_encoder {
    status = "disabled";
};

&right_encoder {
    status = "disabled";
};

