#include "mona2.dtsi"

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    /delete-node/ kscan;

    kscan0: kscan {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };
};

// physical_layoutのkscan参照をmockに上書き
&physical_layout0 {
    kscan = <&kscan0>;
};

