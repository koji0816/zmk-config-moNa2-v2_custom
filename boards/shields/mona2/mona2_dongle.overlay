#include "mona2.dtsi"

// 1. ドングルの空きピンがノイズを拾って暴走するのを防ぐため、物理マトリクスを無効化します
&kscan0 {
    status = "disabled";
};

// 2. 【超重要】物理レイアウトから「ローカルキーボード（ドングル自身）」の紐付けを解除します。
// これにより、ドングルはエラーを起こさず、左右から飛んでくる無線データだけを処理するようになります。
&physical_layout0 {
    /delete-property/ kscan;
};

// 3. 同じくノイズ暴走を防ぐため、ドングルには存在しないエンコーダーを無効化します
&left_encoder {
    status = "disabled";
};

&right_encoder {
    status = "disabled";
};
