#include "mona2.dtsi"

// 1. 左右からのキー位置データを正しく受け取るためのダミー枠（11列×4行）
&kscan0 {
    compatible = "zmk,kscan-mock";
    columns = <11>;
    rows = <4>;
    events = <0>;
    /delete-property/ row-gpios;
    /delete-property/ diode-direction;
    /delete-property/ label;
};

// 2. ディスプレイ（XIAO Round Display）用のタッチボタンをシステムに登録
/ { 
    chosen { 
        zmk,kscan = &xiaord_mock_kscan; 
    }; 
};

// 3. ドングル上の不要なセンサーを無効化（タッチパネルノイズによる誤作動を防止）
&sensors {
    status = "disabled";
};
