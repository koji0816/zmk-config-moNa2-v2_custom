#include "mona2.dtsi"

// 1. ピンの競合を避けつつ、左右からの入力をこぼさず受け取るダミーの受け皿
&kscan0 {
    compatible = "zmk,kscan-mock";
    columns = <11>;
    rows = <4>;
    events = <0>;
    /delete-property/ row-gpios;
    /delete-property/ diode-direction;
    /delete-property/ label;
};

// 2. ドングル上の不要なセンサーを無効化（I2C通信の競合・フリーズ防止）
&sensors {
    status = "disabled";
};

// ※今回は chosen { ... } の呪文は絶対に書きません！
