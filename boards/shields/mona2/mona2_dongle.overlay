#include "mona2.dtsi"

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    /delete-node/ kscan;

    kscan0: kscan {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };
};

&left_encoder {
    status = "disabled";
};
&right_encoder {
    status = "disabled";
};
