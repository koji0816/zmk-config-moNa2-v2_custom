#include "mona2.dtsi"

// 1. ゴースト入力（レイヤー固定）を防ぐため、物理キー枠を無効化
&kscan0 {
    status = "disabled";
};

// 2. ディスプレイ（xiaord）のタッチボタンを有効化
/ {
    chosen {
        zmk,kscan = &xiaord_mock_kscan;
    };
};

// 3. システムを安定させるため、物理レイアウトをダミー枠に紐付け
&physical_layout0 {
    kscan = <&xiaord_mock_kscan>;
};

// 4. 【超重要】センサーシステムは生かしつつ、存在しない物理エンコーダーだけを無効化
// これにより、左手や右手から送られてくるエンコーダーやトラックボールの通信を受け取れるようになります。
&left_encoder { status = "disabled"; };
&right_encoder { status = "disabled"; };
