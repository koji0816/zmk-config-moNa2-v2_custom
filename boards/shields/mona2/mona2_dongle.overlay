#include "mona2.dtsi"

// 1. 物理ピンの競合（ディスプレイのフリーズ）を防ぐため、元のキー枠を無効化します
&kscan0 {
    status = "disabled";
};

// 2. ディスプレイ用のダミー枠をシステムに登録します
/ {
    chosen {
        zmk,kscan = &xiaord_mock_kscan;
    };
};

// 3. システムがクラッシュしないよう、物理レイアウトをダミー枠に紐付けます
&physical_layout0 {
    kscan = <&xiaord_mock_kscan>;
};

// ※エンコーダーの回転を殺してしまうため、&sensors の無効化は絶対に書きません！
