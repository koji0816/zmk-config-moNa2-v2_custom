#include "mona2.dtsi"

// 1. 本来のキーマトリクス（kscan0）を、左右からの通信を受け止める11x4のダミーに作り替えます
&kscan0 {
    compatible = "zmk,kscan-mock";
    columns = <11>;
    rows = <4>;
    events = <0>;
    
    // 物理キー用の設定を削除してエラーを回避
    /delete-property/ row-gpios;
    /delete-property/ diode-direction;
    /delete-property/ label;
};

// 2. ドングル上の不要なセンサーを無効化（フリーズやI2Cの競合を防止）
&sensors {
    status = "disabled";
};
