#include "mona2.dtsi"

// 1. 左右のキー入力を受け取るためのダミーの受け皿（11列×4行）
&kscan0 {
    compatible = "zmk,kscan-mock";
    columns = <11>;
    rows = <4>;
    events = <0>;
    
    // ディスプレイとのピン競合を防ぐため、物理ピンの設定だけを剥がします
    /delete-property/ row-gpios;
    /delete-property/ diode-direction;
};

// 2. ドングルには物理センサーがないため無効化（誤作動防止）
&sensors {
    status = "disabled";
};
