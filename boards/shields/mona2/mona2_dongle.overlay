#include "mona2.dtsi"

// 1. 公式指定：ディスプレイモジュールのタッチボタンをシステムの主役に設定
/ {
    chosen {
        zmk,kscan = &xiaord_mock_kscan;
    };
};

// 2. エラー回避：物理レイアウト（キー配列）がエラーを起こさないよう、参照先を更新
&physical_layout0 {
    kscan = <&xiaord_mock_kscan>;
};

// 3. ノイズ防止：ドングルに存在しない物理キーマトリクスを無効化
&kscan0 {
    status = "disabled";
};

// 4. 【最重要】CPUパンク防止：ドングルに存在しないエンコーダーを無効化（暴走を止める）
&left_encoder {
    status = "disabled";
};

&right_encoder {
    status = "disabled";
};

// ※トラックボールの記述は削除しました
