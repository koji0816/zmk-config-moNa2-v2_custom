#include "mona2.dtsi"

/ {
    chosen {
        zmk,kscan = &xiaord_mock_kscan;
    };

    // kscan0 をGPIOを使わないpassthroughダミーに完全置き換え
    // ZMKのsplitイベントルーティングは維持しつつ、GPIOピン競合を回避
    kscan0: kscan {
        compatible = "zmk,kscan-mock";
        columns = <11>;
        rows = <4>;
        events = <0>;
    };
};

&left_encoder {
    status = "disabled";
};

&right_encoder {
    status = "disabled";
};

&trackball_central_listener {
    status = "okay";
};
