#include "mona2.dtsi"

/ {
    chosen {
        // 【ダミーA】ドングルのローカルキーを0個にして、配列ズレ（コンボ無効化）を防ぎます
        zmk,kscan = &mock_local;
        zmk,matrix-transform = &default_transform;
    };

    mock_local: mock_local {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };

    // 【ダミーB】システム全体に「44キーある」と教え、通常キーがエラーで捨てられるのを防ぎます
    mock_layout: mock_layout {
        compatible = "zmk,kscan-mock";
        columns = <11>;
        rows = <4>;
        events = <0>;
    };
};

// 物理レイアウトをダミーB（11x4）に紐付けます
&physical_layout0 {
    kscan = <&mock_layout>;
};

// ドングルには物理キーがないため、元のマトリクスを無効化
&kscan0 {
    status = "disabled";
};

// 【超重要：ディスプレイ復活の魔法】
// エンコーダーを「XIAOボードには存在しない安全な内部ピン（gpio0 6〜9）」に逃がします。
// これでディスプレイのピンが解放されて画面が復活し、かつシステムも正常に起動します！
&left_encoder {
    status = "okay";
    a-gpios = <&gpio0 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    b-gpios = <&gpio0 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
};

&right_encoder {
    status = "okay";
    a-gpios = <&gpio0 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    b-gpios = <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
};

// センサーシステムはオンのまま維持（キーマップ崩壊を防ぐため）
&sensors {
    status = "okay";
};
