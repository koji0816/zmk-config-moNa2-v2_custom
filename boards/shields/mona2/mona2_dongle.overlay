#include "mona2.dtsi"

// 1. 公式READMEの手順：ドングルの物理キーマトリクスを無効化
&kscan0 {
    status = "disabled";
};

// 2. 公式READMEの手順：xiaordのダミー枠をシステムのkscanに設定
/ {
    chosen {
        zmk,kscan = &xiaord_mock_kscan;
    };
};

// 3. ノイズ誤作動防止：ドングルには存在しないエンコーダーを無効化
&left_encoder {
    status = "disabled";
};

&right_encoder {
    status = "disabled";
};

// 4. 12キー制限の解除：物理レイアウトから誤った紐付けを完全に削除
// これによりキーが切り捨てられる現象が直ります
&physical_layout0 {
    /delete-property/ kscan;
};
