#include "mona2.dtsi"

// 1. ゴースト入力（キーのノイズ連打）を防ぐため、物理ピンの指定だけを削除してダミー化します
&kscan0 {
    compatible = "zmk,kscan-mock";
    columns = <11>;
    rows = <4>;
    events = <0>;
    
    /delete-property/ row-gpios;
    /delete-property/ col-gpios;
    /delete-property/ diode-direction;
};

// 2. ドングル本体の物理エンコーダーピンを無効化し、通信のパンク（大渋滞）を解消します
&left_encoder {
    status = "disabled";
};

&right_encoder {
    status = "disabled";
};

// ※これ以上は何も書きません！
// 画面用の設定（chosen）などはモジュールが自動でやってくれるため、書くとレイアウトが壊れます。
